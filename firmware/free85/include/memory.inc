; Phase 5 RAM contract. The stack grows down from the LCD framebuffer.
SYSTEM_STATE_BASE   EQU $8000
STATE_MAGIC_0       EQU SYSTEM_STATE_BASE + 0
STATE_MAGIC_1       EQU SYSTEM_STATE_BASE + 1
STATE_MAGIC_2       EQU SYSTEM_STATE_BASE + 2
STATE_VERSION       EQU SYSTEM_STATE_BASE + 3
EVENT_FLAGS         EQU SYSTEM_STATE_BASE + 4
TIMER_TICKS_LO      EQU SYSTEM_STATE_BASE + 5
TIMER_TICKS_HI      EQU SYSTEM_STATE_BASE + 6
KEY_CANDIDATE       EQU SYSTEM_STATE_BASE + 7
KEY_STABLE          EQU SYSTEM_STATE_BASE + 8
LAST_KEY            EQU SYSTEM_STATE_BASE + 9
CURRENT_ROM_BANK    EQU SYSTEM_STATE_BASE + 10
UI_SCREEN_MODE      EQU SYSTEM_STATE_BASE + 11
UI_MODIFIERS        EQU SYSTEM_STATE_BASE + 12
UI_MENU_PAGE        EQU SYSTEM_STATE_BASE + 13
UI_CURSOR_VISIBLE   EQU SYSTEM_STATE_BASE + 14
UI_CURSOR_TICK      EQU SYSTEM_STATE_BASE + 15
EDITOR_LENGTH       EQU SYSTEM_STATE_BASE + 16
EDITOR_CURSOR       EQU SYSTEM_STATE_BASE + 17
EDITOR_INSERT       EQU SYSTEM_STATE_BASE + 18
UI_LAST_ACTION      EQU SYSTEM_STATE_BASE + 19
UI_LAST_MODIFIER    EQU SYSTEM_STATE_BASE + 20
EVENT_QUEUE_HEAD    EQU SYSTEM_STATE_BASE + 21
EVENT_QUEUE_TAIL    EQU SYSTEM_STATE_BASE + 22
DIALOG_TITLE_PTR    EQU SYSTEM_STATE_BASE + 23
DIALOG_KIND         EQU SYSTEM_STATE_BASE + 25
ANGLE_MODE          EQU SYSTEM_STATE_BASE + 26

EDITOR_BUFFER       EQU SYSTEM_STATE_BASE + 32
EDITOR_CAPACITY     EQU 48
EVENT_QUEUE         EQU EDITOR_BUFFER + EDITOR_CAPACITY
EVENT_QUEUE_SIZE    EQU 8
RESULT_VISIBLE      EQU EVENT_QUEUE + EVENT_QUEUE_SIZE
RESULT_LENGTH       EQU RESULT_VISIBLE + 1
NUMERIC_ERROR       EQU RESULT_LENGTH + 1
RESULT_BUFFER       EQU $8060
RESULT_CAPACITY     EQU 24

; Public numeric values use sign + signed decimal exponent + fourteen packed
; BCD significant digits. Value = digits * 10^(exponent-13).
NUM_SIZE            EQU 9
NUM_FLAGS           EQU 0
NUM_EXPONENT        EQU 1
NUM_DIGITS          EQU 2
NUM_DIGIT_BYTES     EQU 7
NUM_PRECISION       EQU 14
NUM_SIGN             EQU $80

NUM_LEFT            EQU $8080
NUM_RIGHT           EQU NUM_LEFT + NUM_SIZE
NUM_RESULT          EQU NUM_RIGHT + NUM_SIZE
NUM_SAVED           EQU NUM_RESULT + NUM_SIZE
NUM_WORK_A          EQU $80C0
NUM_WORK_B          EQU NUM_WORK_A + 16
NUM_WORK_R          EQU NUM_WORK_B + 16
NUM_WORK_WIDE       EQU NUM_WORK_R + 16
NUM_SCRATCH         EQU NUM_WORK_WIDE + 30
NUM_WORK_END        EQU NUM_SCRATCH + 32

TOKEN_SIZE          EQU 3
TOKEN_CAPACITY      EQU 48
TOKEN_BUFFER        EQU $8140
EVAL_STACK_CAPACITY EQU 8
EVAL_STACK          EQU TOKEN_BUFFER + TOKEN_SIZE * TOKEN_CAPACITY
VARIABLE_COUNT      EQU 26
VARIABLES           EQU EVAL_STACK + EVAL_STACK_CAPACITY * NUM_SIZE
PREVIOUS_ANSWER     EQU VARIABLES + VARIABLE_COUNT * NUM_SIZE
HISTORY_HEAD        EQU PREVIOUS_ANSWER + NUM_SIZE
HISTORY_COUNT       EQU HISTORY_HEAD + 1
HISTORY_NAV         EQU HISTORY_COUNT + 1
HISTORY_SLOTS       EQU 4
HISTORY_SLOT_SIZE   EQU EDITOR_CAPACITY + 1
HISTORY_BUFFER      EQU HISTORY_NAV + 1
PARSER_STATE        EQU HISTORY_BUFFER + HISTORY_SLOTS * HISTORY_SLOT_SIZE
SCI_BASE            EQU $8400
SCI_X               EQU SCI_BASE
SCI_TERM            EQU SCI_X + NUM_SIZE
SCI_SUM              EQU SCI_TERM + NUM_SIZE
SCI_TEMP             EQU SCI_SUM + NUM_SIZE
SCI_AUX              EQU SCI_TEMP + NUM_SIZE
SCI_AUX2             EQU SCI_AUX + NUM_SIZE
SCI_SAVED            EQU SCI_AUX2 + NUM_SIZE
SCI_STATE            EQU SCI_SAVED + NUM_SIZE
SYSTEM_STATE_END    EQU SCI_STATE + 32

; Phase 6 graph/application RAM. Equation slots contain a length byte followed
; by the same 48-byte source representation used by the home editor.
GRAPH_BASE          EQU $8500
GRAPH_ACTIVE_SLOT   EQU GRAPH_BASE + 0
GRAPH_ENABLED       EQU GRAPH_BASE + 1
GRAPH_PLOT_ACTIVE   EQU GRAPH_BASE + 2
GRAPH_PLOT_X        EQU GRAPH_BASE + 3
GRAPH_TRACE_X       EQU GRAPH_BASE + 4
GRAPH_GRID          EQU GRAPH_BASE + 5
GRAPH_NUMERIC_OP    EQU GRAPH_BASE + 6
GRAPH_STATUS        EQU GRAPH_BASE + 7
GRAPH_PREV_VALID    EQU GRAPH_BASE + 8
GRAPH_PREV_Y1       EQU GRAPH_BASE + 9
GRAPH_PREV_Y2       EQU GRAPH_BASE + 10
GRAPH_PREV_Y3       EQU GRAPH_BASE + 11
GRAPH_EQ1           EQU GRAPH_BASE + 16
GRAPH_EQ2           EQU GRAPH_EQ1 + EDITOR_CAPACITY + 1
GRAPH_EQ3           EQU GRAPH_EQ2 + EDITOR_CAPACITY + 1
GRAPH_XMIN          EQU $8600
GRAPH_XMAX          EQU GRAPH_XMIN + NUM_SIZE
GRAPH_YMIN          EQU GRAPH_XMAX + NUM_SIZE
GRAPH_YMAX          EQU GRAPH_YMIN + NUM_SIZE
GRAPH_XSTEP         EQU GRAPH_YMAX + NUM_SIZE
GRAPH_CURRENT_X     EQU GRAPH_XSTEP + NUM_SIZE
GRAPH_TABLE_START   EQU GRAPH_CURRENT_X + NUM_SIZE
GRAPH_TABLE_STEP    EQU GRAPH_TABLE_START + NUM_SIZE
GRAPH_TOLERANCE     EQU GRAPH_TABLE_STEP + NUM_SIZE
GRAPH_WORK_0        EQU GRAPH_TOLERANCE + NUM_SIZE
GRAPH_WORK_1        EQU GRAPH_WORK_0 + NUM_SIZE
GRAPH_WORK_2        EQU GRAPH_WORK_1 + NUM_SIZE
GRAPH_WORK_3        EQU GRAPH_WORK_2 + NUM_SIZE
GRAPH_RESULT_X      EQU GRAPH_WORK_3 + NUM_SIZE
GRAPH_RESULT_Y      EQU GRAPH_RESULT_X + NUM_SIZE
PHASE6_STATE_END    EQU $8700

ANGLE_RADIANS       EQU 0
ANGLE_DEGREES       EQU 1

NUM_ERR_NONE        EQU 0
NUM_ERR_SYNTAX      EQU 1
NUM_ERR_DIV_ZERO    EQU 2
NUM_ERR_OVERFLOW    EQU 3
NUM_ERR_DOMAIN      EQU 4

SCREEN_HOME         EQU 0
SCREEN_DIALOG       EQU 1
SCREEN_GRAPH        EQU 2
SCREEN_TABLE        EQU 3

MODIFIER_SECOND     EQU $01
MODIFIER_ALPHA      EQU $02
MODIFIER_ALPHA_LOCK EQU $04

ACTION_MODIFIER_NONE   EQU 0
ACTION_MODIFIER_SECOND EQU 1
ACTION_MODIFIER_ALPHA  EQU 2

STACK_BOTTOM        EQU $FB00
STACK_TOP           EQU $FC00
LCD_FRAMEBUFFER     EQU $FC00
LCD_FRAMEBUFFER_END EQU $10000
LCD_ROW_BYTES       EQU 16
LCD_SIZE_BYTES      EQU 1024

PHASE6_INIT         EQU $4008
PHASE6_OPEN_GRAPH   EQU $400B
PHASE6_HANDLE_KEY   EQU $400E
PHASE6_TICK         EQU $4011
PHASE6_SOLVE_HOME   EQU $4014
PHASE6_TOLERANCE_UI EQU $4017

PHASE6_STATE_BYTES  EQU PHASE6_STATE_END - SYSTEM_STATE_BASE
PHASE6_STACK_BYTES  EQU STACK_TOP - STACK_BOTTOM
PHASE6_RAM_BYTES    EQU PHASE6_STATE_BYTES + PHASE6_STACK_BYTES + LCD_SIZE_BYTES
